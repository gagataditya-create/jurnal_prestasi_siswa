rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened ID validation helper
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Strict validation blueprint for achievement records
    function isValidAchievement(data) {
      return data.namaSiswa is string 
        && data.namaSiswa.size() >= 2 
        && data.namaSiswa.size() <= 100
        && data.jenisPrestasi is string 
        && (data.jenisPrestasi == 'Akademik' || data.jenisPrestasi == 'Olahraga' || data.jenisPrestasi == 'Seni' || data.jenisPrestasi == 'Keagamaan' || data.jenisPrestasi == 'Non-Akademik' || data.jenisPrestasi == 'Lainnya')
        && data.tanggal is string 
        && data.tanggal.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.deskripsi is string 
        && data.deskripsi.size() >= 5 
        && data.deskripsi.size() <= 1000;
    }

    match /achievements/{achievementId} {
      // Public read capability for display dashboard
      allow read, list: if true;
      
      // Strictly validated write operations to prevent junk injection
      allow create: if isValidId(achievementId) && isValidAchievement(incoming());
      allow update: if isValidId(achievementId) && isValidAchievement(incoming());
      allow delete: if isValidId(achievementId);
    }
  }
}
